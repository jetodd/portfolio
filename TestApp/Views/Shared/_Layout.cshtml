<!DOCTYPE html>
<html>
<head>
    <title>@ViewBag.Title</title>
    <link href="~/Content/jquery.fullpage.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
    <script src="@Url.Content("~/Scripts/jquery-1.8.2.min.js")"></script>
    <script src="@Url.Content("~/Scripts/jquery.fullpage.min.js")"></script>
    <script src="@Url.Content("~/Scripts/Balloon.js")"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $(function () {
                $('#navigation a').stop().animate({ 'marginLeft': '-90px' }, 1000);

                $('#navigation > li').hover(
                 function () {
                     $('a', $(this)).stop().animate({ 'marginLeft': '-2px' }, 200);
                 },
                 function () {
                     $('a', $(this)).stop().animate({ 'marginLeft': '-90px' }, 200);
                 }
                );
            });
           
        });
       
    </script>
</head>
    <body>

        <div id="container">
            <ul id="navigation">
                <li class="home"><a title="Home">Home</a></li>
                <li class="about"><a title="About">About</a></li>
                <li class="search"><a title="Search">Portfolio</a></li>
            </ul>

            <div id="hide" style="display: none;">
                @RenderBody()
            </div>

            <div class="circle"><div class="pop"></div></div>
            <div class="circle-multiline"></div>
        
            <div id="wrap">
                <div class="fish">
                    <img src="~/Content/Images/orange.png" />
                </div>
                <div class="bubble">
                    <img src="~/Content/Images/red.png" />
                </div>
            </div>
        </div>


    </body>
</html>